generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum DemoRequestStatus {
  NEW
  CONTACTED
  SCHEDULED
  COMPLETED
  LOST
}

enum ClientStatus {
  ACTIVE
  CHURNED
  PAUSED
}

enum ContractType {
  ANNUAL
  MONTHLY
  ENTERPRISE
}

enum ContractStatus {
  ACTIVE
  EXPIRED
  PENDING
  CANCELLED
}

enum PipelineStage {
  LEAD
  DEMO_REQUESTED
  DEMO_SCHEDULED
  DEMO_DONE
  PROPOSAL_SENT
  NEGOTIATING
  CLOSED_WON
  CLOSED_LOST
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  active    Boolean  @default(true)

  assignedDemoRequests DemoRequest[] @relation("DemoAssignee")
  managedClients       Client[]      @relation("ClientManager")
  assignedDeals        Deal[]        @relation("DealAssignee")
  activities           Activity[]    @relation("ActivityActor")
  reports                Report[]      @relation("ReportAuthor")

  @@map("users")
}

model DemoRequest {
  id           String            @id @default(cuid())
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  name         String
  company      String
  role         String
  email        String
  industry     String
  message      String            @default("")
  status       DemoRequestStatus @default(NEW)
  assignedToId String?
  assignedTo   User?             @relation("DemoAssignee", fields: [assignedToId], references: [id])
  notes        String            @default("")
  activities   Activity[]

  @@map("demo_requests")
}

model Client {
  id              String       @id @default(cuid())
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  companyName     String
  industry        String
  contractValue   Float        @default(0)
  startDate       DateTime?
  status          ClientStatus @default(ACTIVE)
  assignedToId    String?
  assignedTo      User?        @relation("ClientManager", fields: [assignedToId], references: [id])
  healthScore     Int          @default(80)
  notes           String       @default("")
  address         String       @default("")
  billingEmail    String       @default("")
  pmiDealsJson    String       @default("[]")
  contacts        Contact[]
  deals           Deal[]
  contracts       Contract[]
  activities      Activity[]
  invoices        Invoice[]

  @@map("clients")
}

model Contact {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name     String
  role     String
  email    String
  phone    String @default("")

  @@map("contacts")
}

model Deal {
  id             String         @id @default(cuid())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  companyName    String
  stage          PipelineStage  @default(LEAD)
  estimatedValue Float          @default(0)
  probability    Int            @default(10)
  assignedToId   String?
  assignedTo     User?          @relation("DealAssignee", fields: [assignedToId], references: [id])
  nextAction       String         @default("")
  clientId       String?
  client         Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  stageEnteredAt DateTime       @default(now())
  activities     Activity[]

  @@map("crm_deals")
}

model Contract {
  id         String         @id @default(cuid())
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  clientId   String
  client     Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type       ContractType
  value      Float
  startDate  DateTime
  endDate    DateTime
  status     ContractStatus @default(ACTIVE)
  autoRenew  Boolean        @default(false)
  pdfUrl     String         @default("")
  activities Activity[]

  @@map("contracts")
}

model Invoice {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  amount    Float
  issuedAt  DateTime
  status    String   @default("PAID")
  memo      String   @default("")

  @@map("invoices")
}

model Activity {
  id            String       @id @default(cuid())
  createdAt     DateTime     @default(now())
  type          String
  title         String
  description   String       @default("")
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id])
  demoRequestId String?
  demoRequest   DemoRequest? @relation(fields: [demoRequestId], references: [id])
  dealId        String?
  deal          Deal?        @relation(fields: [dealId], references: [id])
  contractId    String?
  contract      Contract?    @relation(fields: [contractId], references: [id])
  actorId       String?
  actor         User?        @relation("ActivityActor", fields: [actorId], references: [id])

  @@map("activities")
}

model Report {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  title       String
  year        Int?
  dateFrom    DateTime
  dateTo      DateTime
  summaryJson String   @default("{}")
  pdfBase64   String   @default("")
  createdById String?
  createdBy   User?    @relation("ReportAuthor", fields: [createdById], references: [id])

  @@map("reports")
}

model CrmSettings {
  id                      String @id @default("singleton")
  companyName             String @default("Converis AI")
  companyLogoUrl          String @default("")
  companyAddress          String @default("")
  billingInfo             String @default("")
  emailTemplatesJson      String @default("{}")
  integrationsJson        String @default("{}")
  notificationPrefsJson   String @default("{}")
  emailNotificationsJson  String @default("{}")

  @@map("crm_settings")
}
